# ────────────────────────────────────────────────────────────────────────────
#  .env.local.example  —  환경변수 템플릿 (전부 빈 값)
# ────────────────────────────────────────────────────────────────────────────
#  사용법:  cp .env.local.example .env.local   후 값 채우기
#  ⚠️ .env.local 은 .gitignore 로 커밋되지 않는다. 비밀은 절대 커밋하지 말 것.
#  브랜드(공개 정체성)는 여기가 아니라 brand.config.ts 에서 관리한다.
#  변수명은 코드(process.env.*)가 실제로 읽는 이름 그대로다 — 바꾸면 인식 안 됨.
# ────────────────────────────────────────────────────────────────────────────

# ─── 필수: 발송 (Resend) ───────────────────────────────────────────────────
# 발송·트랜잭션·라이브 상태조회에 모두 쓰이는 단일 키 (full access 권장).
# 발급: https://resend.com → API Keys → Create
RESEND_EMAIL_TRACKING_API_KEY=

# ─── 필수: 세션 서명 (JWT, HS256) ──────────────────────────────────────────
# 생성: openssl rand -base64 32
# (JWT_SECRET 이름으로도 인식됨 — 둘 중 하나만 채우면 된다)
AUTH_SESSION_SECRET=

# ─── 필수: 이미지 스토리지 (현재 어댑터 = Azure Blob) ──────────────────────
# brand.config.ts 의 assets.provider 가 "azure" 일 때 사용.
# ⚠️ 개인 프로젝트는 Cloudflare R2 등으로 교체 예정 — R2 어댑터 구현 후
#    아래 Azure 블록 대신 R2_* 를 쓴다(주석 참고).
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER=

# (구현 예정) Cloudflare R2 어댑터용 — lib/storage/adapters/r2.ts 추가 후 사용
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_BASE=

# ─── 인증: Google OAuth (auth.mode 가 google 일 때만 필요) ──────────────────
# 발급: Google Cloud Console → API 및 서비스 → 사용자 인증 정보
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# (구현 예정) password 모드 — 단일 비밀번호 게이트 (auth.mode = password)
# ACCESS_PASSWORD=

# ─── 선택: 관리자 / 앱 URL ─────────────────────────────────────────────────
# ADMIN_EMAILS: 쉼표 구분. 남의 리스트·템플릿·발신자 관리 권한.
ADMIN_EMAILS=
# APP_BASE_URL: 수신거부 링크 베이스. 미설정 시 brand.config 의 appBaseUrl 사용.
APP_BASE_URL=

# ─── 선택: 컴플라이언스 푸터 (미설정 시 brand.config 기본값) ────────────────
SENDER_ORG_NAME=
# ⚠️ 외부 발송 전 반드시 채울 것 (CAN-SPAM·정보통신망법상 물리주소 의무)
SENDER_POSTAL_ADDRESS=
SENDER_CONTACT_EMAIL=

# ─── 선택: Resend Webhook 서명 검증 ────────────────────────────────────────
# Resend → Webhooks → Signing Secret
RESEND_WEBHOOK_SECRET=

# ─── 선택: 발송 남용 방지 상한 (미설정 시 괄호 안 기본값) ───────────────────
# MAX_RECIPIENTS_PER_SEND=     # (기본 1000) 1회 발송 최대 수신자
# USER_DAILY_SEND_LIMIT=       # (기본 5000) 24시간 누적 상한
# USER_HOURLY_SEND_LIMIT=      # (기본 2000) 1시간 누적 상한
# SEND_MIN_GAP_MS=             # (기본 220)  발송 간 최소 간격(ms)
