# ────────────────────────────────────────────────────────────────────────────
#  .env.local.example  —  environment variable template (all values empty)
# ────────────────────────────────────────────────────────────────────────────
#  Usage:  cp .env.local.example .env.local   then fill in the values
#  ⚠️ .env.local is gitignored and never committed. Never commit secrets.
#  Brand (public identity) is managed in brand.config.ts, not here.
#  Variable names match exactly what the code reads (process.env.*) — renaming breaks recognition.
# ────────────────────────────────────────────────────────────────────────────

# ─── Required: sending (Resend) ────────────────────────────────────────────
# Single key used for sending, transactions, and live status lookups (full access recommended).
# Get one: https://resend.com → API Keys → Create
RESEND_EMAIL_TRACKING_API_KEY=

# ─── Required: session signing (JWT, HS256) ────────────────────────────────
# Generate: openssl rand -base64 32
# (Also recognized under the name JWT_SECRET — fill in just one of the two)
AUTH_SESSION_SECRET=

# ─── Required: image storage (current adapter = Azure Blob) ────────────────
# Used when assets.provider in brand.config.ts is "azure".
# ⚠️ Personal projects will switch to Cloudflare R2 etc. — after implementing the R2
#    adapter, use R2_* instead of the Azure block below (see comments).
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER=

# (Planned) For the Cloudflare R2 adapter — use after adding lib/storage/adapters/r2.ts
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_BASE=

# ─── Auth: Google OAuth (only needed when auth.mode is google) ─────────────
# Get one: Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# (Planned) password mode — single-password gate (auth.mode = password)
# ACCESS_PASSWORD=

# ─── Optional: admins / app URL ────────────────────────────────────────────
# ADMIN_EMAILS: comma-separated. Permission to manage others' lists, templates, and senders.
ADMIN_EMAILS=
# APP_BASE_URL: base for unsubscribe links. If unset, uses appBaseUrl from brand.config.
APP_BASE_URL=

# ─── Optional: compliance footer (falls back to brand.config defaults if unset) ────
SENDER_ORG_NAME=
# ⚠️ Must be filled before external sends (physical address required by CAN-SPAM and the Network Act).
SENDER_POSTAL_ADDRESS=
SENDER_CONTACT_EMAIL=

# ─── Optional: Resend webhook signature verification ───────────────────────
# Resend → Webhooks → Signing Secret
RESEND_WEBHOOK_SECRET=

# ─── Optional: send abuse-prevention limits (defaults in parentheses if unset) ─────
# MAX_RECIPIENTS_PER_SEND=     # (default 1000) max recipients per send
# USER_DAILY_SEND_LIMIT=       # (default 5000) cumulative 24-hour limit
# USER_HOURLY_SEND_LIMIT=      # (default 2000) cumulative 1-hour limit
# SEND_MIN_GAP_MS=             # (default 220)  minimum gap between sends (ms)
